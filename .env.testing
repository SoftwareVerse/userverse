# Userverse example testing configuration
# Copy values from here into `.env` or load this file explicitly for local testing.

# Application
ENVIRONMENT=testing
TESTING=true
SERVER_URL=http://localhost:8000
APP_NAME=Userverse
APP_DESCRIPTION=Userverse backend API
APP_VERSION=0.6.20
REPOSITORY=https://github.com/SoftwareVerse/userverse.git
DOCUMENTATION=https://userverse.softwareverse.co.za/docs

# Database
# Option 1: provide DATABASE_URL directly.
DATABASE_URL=sqlite:///./test.db

# Option 2: use DB_* parts instead of DATABASE_URL.
# DB_TYPE=postgresql
# DB_USER=userverse
# DB_PASSWORD=change-me
# DB_NAME=userverse
# DB_HOST=localhost
# DB_PORT=5432

DB_AUTO_CREATE=true
DB_ECHO=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
REQUIRE_EMAIL_VERIFICATION=true

# CORS
# Comma-separated values or JSON arrays both work.
CORS_ALLOWED=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:5173","http://127.0.0.1:5173"]
CORS_BLOCKED=["http://localhost:3000"]

# JWT
JWT_SECRET=change-this-testing-secret
JWT_ALGORITHM=HS256
JWT_TIMEOUT=30
JWT_REFRESH_TIMEOUT=60

# Email
# In test mode the app will skip SMTP delivery, but these are included as examples.
EMAIL_HOST=smtp.example.com
EMAIL_PORT=465
EMAIL_USERNAME=no-reply@example.com
EMAIL_PASSWORD=change-me
EMAIL_SSL=true
EMAIL_TLS=false
